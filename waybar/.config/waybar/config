{
  "layer": "top",
  "modules-left": ["hyprland/workspaces", "custom/playerctl"],
  "modules-center": ["hyprland/window"],
  "modules-right": ["cpu", "memory", "pulseaudio", "network", "battery", "battery#bat2", "clock", "tray"],
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}: {icon}",
    "format-icons": {
      "urgent": "ΎΒς ",
      "focused": "ΎΗΤ ",
      "default": "ΎΕΝ "
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
      "6": [],
      "7": [],
      "8": [],
      "9": [],
    },
  },
  "hyprland/window": {
    "max-length": 50,
    "tooltip": false
  },
  "clock": {
    "format": "{:%I:%M %p %Z}",
    "format-alt": "{:%m-%d-%Y}",
    "tooltip": false
  },
  "cpu": {
    "format": "ΌΚο  {usage:2}%",
    "interval": 5,
    "tooltip": false
  },
  "memory": {
    "format": "ΎΔΚ  {percentage:2}%",
    "interval": 5,
    "tooltip": false
  },
  "battery": {
    "bat": "BAT0",
    "interval": 60,
    "states": {
      "good": 100,
      "warning": 25,
      "critical": 10
    },
    "format": "{icon}  {capacity}%",
    "format-icons": ["ΎΚΕ ", "ΎΚΔ ", "ΎΚΓ ", "ΎΚΒ ", "ΎΚΑ "],
    "tooltip": false
  },
  "battery#bat2": {
    "bat": "BAT1",
    "interval": 60,
    "states": {
      "good": 100,
      "warning": 25,
      "critical": 10
    },
    "format": "{icon}  {capacity}%",
    "format-icons": ["ΎΚΕ ", "ΎΚΔ ", "ΎΚΓ ", "ΎΚΒ ", "ΎΚΑ "],
    "tooltip": false
  },
  "network": {
    "format-wifi": "ΎΘτ  {essid} ({signalStrength}%)",
    "format-ethernet": "≤░ΙΑ  {ifname}",
    "format-disconnected": "έγι  Disconnected",
    "interval": 5,
    "tooltip": false
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon}ΎΛΦ {volume}%",
    "format-muted": "ΎΑο ",
    "format-icons": {
      "headphones": "ΎΑξ ",
      "handsfree": "ΎΑξ ",
      "headset": "ΎΑξ ",
      "phone": "ΎΓΧ ",
      "portable": "ΎΓΧ ",
      "car": "ΎΗ╣ ",
      "default": ["ΎΑπ ", "ΎΑρ "]
    },
    "tooltip": false,
    "on-click": "pavucontrol"
  },
  "tray": {
    "icon-size": 18,
    "spacing": 10
  }
}
